STT_PORT=8001
MODEL_HOST_DIR=../models/stt

MODEL_ID=ghost613/faster-whisper-large-v3-turbo-korean
DEVICE=cuda
COMPUTE_TYPE=float16
DEFAULT_LANGUAGE=ko
DEFAULT_BEAM_SIZE=5
DEFAULT_BATCH_SIZE=2

STT_BASE_URL=http://localhost:8001
STT_MODEL=whisper-1
STT_LANGUAGE=ko
STT_HEALTH_RETRIES=20
STT_HEALTH_BACKOFF_SEC=2
STT_BEAM_SIZE=5
STT_CHUNK_SECONDS=600
STT_CHUNK_OVERLAP_SECONDS=2
STT_OUTPUT_DIR=./scripts/outputs
YOUTUBE_URL=https://www.youtube.com/watch?v=ZYbKUUrbatI
